  "title": "Na'vi Vowels",
  "objective": "Learn the basic vowels used in the Na'vi language.",
  "content": [
    {
      "id": 1,
      "type": "text",
      "data": {
        "text": "Na'vi is a phonetic language. Meaning a letter is pronounced the same way each time. The language has 33 sounds. This lesson will focus on the vowels first."
      }
    },
    {
      "id": 2,
      "type": "text",
      "data": {
        "text": "Na'vi has 7 vowels: a, ä, e, i, ì, o, u."
      }
    },
    {
      "id": 3,
      "type": "character",
      "data": {
        "letter": "a",
        "ttsHint": "ah",
        "description": "Pronounced like the 'a' in the English word 'father' or 'car'."
      }
    },
    {
      "id": 4,
      "type": "character",
      "data": {
        "letter": "ä",
        "ttsHint": "aa",
        "description": "Pronounced like the 'a' in the English word 'cat' or 'pack'. "
      }
    },
    {
      "id": 5,
      "type": "character",
      "data": {
        "letter": "e",
        "ttsHint": "eh",
        "description": "Pronounced like the 'e' in the English word 'then' or 'set'. "
      }
    },
    {
      "id": 6,
      "type": "character",
      "data": {
        "letter": "i",
        "ttsHint": "ee",
        "description": "Pronounced like the 'i' in the English word 'machine'. It sounds similar to the English letter 'e'."
      }
    },
    {
      "id": 7,
      "type": "character",
      "data": {
        "letter": "ì",
        "ttsHint": "ih",
        "description": "Pronounced like the 'i' in the English word 'bit' or 'thin'."
      }
    },
    {
      "id": 8,
      "type": "character",
      "data": {
        "letter": "o",
        "ttsHint": "oh",
        "description": "Pronounced like the 'o' in the English word 'own' or 'more'."
      }
    },
    {
      "id": 9,
      "type": "character",
      "data": {
        "letter": "u",
        "ttsHint": "oo",
        "description": "Pronounced like the 'u' in the English word 'dude'."
      }
    },
